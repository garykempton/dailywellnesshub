generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Content ────────────────────────────────────────────────────────

model Article {
  id            String        @id @default(cuid())
  slug          String        @unique
  title         String
  metaTitle     String?
  metaDesc      String?       @db.VarChar(320)
  excerpt       String?       @db.VarChar(500)
  summary       String?       @db.Text     // longer editorial summary (internal use + display)
  body          String        @db.Text
  category      Category      @relation(fields: [categorySlug], references: [slug])
  categorySlug  String
  tags          Tag[]
  keywords      String[]                   // target SEO keywords
  coverImage    String?
  coverAlt      String?
  author        String        @default("DailyWellnessHub Editorial")
  authorBio     String?       @db.VarChar(500)

  // ─── Publishing workflow ────────────────────────────────────────
  status        ArticleStatus @default(DRAFT)
  publishedAt   DateTime?
  featured      Boolean       @default(false)

  // ─── Review & fact-check ────────────────────────────────────────
  healthSensitive  Boolean          @default(false)  // blocks auto-publish
  factCheckStatus  FactCheckStatus  @default(UNCHECKED)
  factCheckedBy    String?
  factCheckedAt    DateTime?
  factCheckNotes   String?          @db.Text
  reviewStatus     ReviewStatus     @default(UNREVIEWED)
  reviewedBy       String?
  reviewedAt       DateTime?
  reviewNotes      String?          @db.Text

  // ─── Affiliate ─────────────────────────────────────────────────
  affiliateStatus  AffiliateStatus  @default(NONE)
  affiliateNote    String?          @db.Text   // disclosure text
  affiliateLinks   String?          @db.Text   // JSON array of {url, label, vendor}

  // ─── Sources & references ──────────────────────────────────────
  sources          String?       @db.Text   // JSON array of source URLs
  sourceNotes      String?       @db.Text   // editorial notes on sourcing

  // ─── FAQ section ───────────────────────────────────────────────
  faqSection       String?       @db.Text   // JSON array of {question, answer}

  // ─── Internal links & related ──────────────────────────────────
  internalLinks    String?       @db.Text   // JSON array of {slug, anchor}
  relatedTools     String[]                 // slugs of related calculator/tool pages
  relatedArticles  String[]                 // slugs of related articles

  // ─── Metrics ───────────────────────────────────────────────────
  wordCount     Int           @default(0)
  readTime      Int           @default(0)

  // ─── Timestamps ────────────────────────────────────────────────
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // ─── AI generation metadata ────────────────────────────────────
  aiGenerated   Boolean       @default(false)
  aiModel       String?
  aiPrompt      String?       @db.Text

  @@index([categorySlug])
  @@index([status, publishedAt])
  @@index([featured, status])
  @@index([healthSensitive, status])
  @@index([factCheckStatus])
  @@index([reviewStatus])
}

enum ArticleStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum FactCheckStatus {
  UNCHECKED
  PENDING
  VERIFIED
  DISPUTED
  NOT_APPLICABLE
}

enum ReviewStatus {
  UNREVIEWED
  PENDING_REVIEW
  CHANGES_REQUESTED
  APPROVED
  REJECTED
}

enum AffiliateStatus {
  NONE
  HAS_LINKS
  DISCLOSED
  PENDING_APPROVAL
}

model Category {
  slug            String    @id
  name            String
  description     String?   @db.VarChar(500)
  metaTitle       String?
  metaDesc        String?   @db.VarChar(320)
  icon            String?
  sortOrder       Int       @default(0)
  healthSensitive Boolean   @default(false)  // auto-flags articles in this category
  articles        Article[]

  @@index([sortOrder])
}

model Tag {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  articles Article[]

  @@index([slug])
}

// ─── Newsletter ─────────────────────────────────────────────────────

model Subscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  confirmed      Boolean   @default(false)
  interests      String[]
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?

  @@index([confirmed])
}

// ─── Contact ────────────────────────────────────────────────────────

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── AI Content Pipeline ────────────────────────────────────────────

model ContentJob {
  id          String    @id @default(cuid())
  topic       String
  category    String
  keywords    String[]
  targetSlug  String?
  status      JobStatus @default(PENDING)
  articleId   String?
  error       String?   @db.Text
  createdAt   DateTime  @default(now())
  completedAt DateTime?
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
